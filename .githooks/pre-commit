#!/bin/bash
# Pre-commit hook: Run tests before allowing commit
# Uses --last-failed --fail-first for speed on repeat runs,
# falls back to full suite on first run or when all previously passed.

echo "Running tests..."

# Fast path: re-run only previously failed tests first
python -m pytest tests/unit -q --tb=line --lf --ff -x 2>/dev/null

if [ $? -ne 0 ]; then
    echo ""
    echo "Tests failed! Commit blocked."
    echo "Fix the failing tests or use --no-verify to skip (not recommended)."
    exit 1
fi

echo "All tests passed!"
exit 0
